{
  "name": "gmail-manager",
  "private": true,
  "workspaces": ["server", "client"],
  "scripts": {
    "dev": "concurrently \"bun run --cwd server dev\" \"bun run --cwd client dev\"",
    "build": "bun run --cwd client build",
    "db:generate": "bun run --cwd server db:generate",
    "db:migrate": "bun run --cwd server db:migrate"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
