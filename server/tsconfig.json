  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules",
      "../node_modules/@types",
      "../node_modules"
    ]
  }
}
