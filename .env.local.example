# npx supabase start の出力から貼る値
#   "Project URL"  → NEXT_PUBLIC_SUPABASE_URL
#   "Publishable"  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   "Database URL" → DATABASE_URL
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Google OAuth (Google Cloud Console で取得)
# supabase/config.toml の env() が参照する。npx supabase start の前に export すること。
#   "クライアント ID"        → SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID
#   "クライアントシークレット" → SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
